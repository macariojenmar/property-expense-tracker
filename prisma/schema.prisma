generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("PRISMA_DATABASE_URL")
  directUrl = env("POSTGRES_URL")
}

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String?          @unique
  emailVerified   DateTime?
  password        String?
  image           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  accountType     AccountType      @default(TRIAL)
  role            UserRole         @default(USER)
  status          UserStatus       @default(PENDING)
  expiredAt       DateTime?
  accounts        Account[]
  sessions        Session[]
  dictionaryWords DictionaryWord[]
  pendingToEs     PendingTo[]
  properties      Property[]
}

model Property {
  id                      String                  @id @default(cuid())
  name                    String
  location                String?
  price                   Float?                  @default(0)
  initialFunds            Float?                  @default(0)
  userId                  String
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  expenses                Expense[]
  payouts                 Payout[]
  user                    User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  recurringExpenses       RecurringExpense[]
  waivedRecurringExpenses RecurringExpenseWaive[]
}

model Expense {
  id           String        @id @default(cuid())
  name         String
  amount       Float
  note         String?
  date         DateTime
  propertyId   String
  isRecurring  Boolean       @default(false)
  recurringRef String?
  status       ExpenseStatus @default(SETTLED)
  pendingToId  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  pendingTo    PendingTo?    @relation(fields: [pendingToId], references: [id])
  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model PendingTo {
  id                String             @id @default(cuid())
  name              String
  type              String?
  userId            String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  expenses          Expense[]
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  recurringExpenses RecurringExpense[]
}

model Payout {
  id           String       @id @default(cuid())
  amount       Float
  date         DateTime
  propertyId   String
  refundAmount Float?       @default(0)
  status       PayoutStatus @default(PAID)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  name         String?
  property     Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model RecurringExpense {
  id          String                  @id @default(cuid())
  name        String
  amount      Float
  day         Int
  propertyId  String
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  pendingToId String?
  pendingTo   PendingTo?              @relation(fields: [pendingToId], references: [id])
  property    Property                @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  waives      RecurringExpenseWaive[]
}

model RecurringExpenseWaive {
  id                 String           @id @default(cuid())
  monthKey           String
  recurringExpenseId String
  propertyId         String
  createdAt          DateTime         @default(now())
  property           Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  recurringExpense   RecurringExpense @relation(fields: [recurringExpenseId], references: [id], onDelete: Cascade)

  @@unique([monthKey, recurringExpenseId, propertyId])
}

model DictionaryWord {
  id        String   @id @default(cuid())
  word      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([word, userId])
}

model PlatformSetting {
  id                      String   @id @default("default")
  trialPeriodDays         Int      @default(7)
  trialMaxProperties      Int      @default(1)
  trialMaxEntities        Int      @default(2)
  trialMaxDictionaries    Int      @default(5)
  trialMaxExpenses        Int      @default(10)
  trialMaxPayouts         Int      @default(5)
  standardMaxProperties   Int      @default(5)
  standardMaxEntities     Int      @default(5)
  standardMaxDictionaries Int      @default(10)
  standardMaxExpenses     Int      @default(-1)
  standardMaxPayouts      Int      @default(-1)
  proMaxProperties        Int      @default(-1)
  proMaxEntities          Int      @default(-1)
  proMaxDictionaries      Int      @default(-1)
  proMaxExpenses          Int      @default(-1)
  proMaxPayouts           Int      @default(-1)
  updatedAt               DateTime @updatedAt
}

enum UserRole {
  USER
  DEVELOPER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
  DELETED
}

enum AccountType {
  TRIAL
  STANDARD
  PRO
}

enum ExpenseStatus {
  PENDING
  SETTLED
  DELETED
}

enum PayoutStatus {
  PAID
  REFUNDED
  PARTIALLY_REFUNDED
  DELETED
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

