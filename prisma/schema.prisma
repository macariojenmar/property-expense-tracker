// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
  directUrl = env("POSTGRES_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  image         String?
  properties    Property[]
  pendingToEs   PendingTo[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Property {
  id                String             @id @default(cuid())
  name              String
  location          String?
  price             Float?             @default(0)
  initialFunds      Float?             @default(0)
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses          Expense[]
  payouts           Payout[]
  recurringExpenses RecurringExpense[]
  waivedRecurringExpenses RecurringExpenseWaive[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Expense {
  id           String         @id @default(cuid())
  name         String
  amount       Float
  note         String?
  date         DateTime
  propertyId   String
  property     Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  isRecurring  Boolean        @default(false)
  recurringRef String?
  status       ExpenseStatus  @default(SETTLED)
  pendingToId  String?
  pendingTo    PendingTo?     @relation(fields: [pendingToId], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

enum ExpenseStatus {
  PENDING
  SETTLED
  DELETED
}

model PendingTo {
  id        String    @id @default(cuid())
  name      String
  type      String?   // e.g., "Person", "Organization"
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses  Expense[]
  recurringExpenses RecurringExpense[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Payout {
  id           String       @id @default(cuid())
  name         String?
  amount       Float
  date         DateTime
  propertyId   String
  property     Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  refundAmount Float?       @default(0)
  status       PayoutStatus @default(PAID)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

enum PayoutStatus {
  PAID
  REFUNDED
  PARTIALLY_REFUNDED
  DELETED
}

model RecurringExpense {
  id         String   @id @default(cuid())
  name       String
  amount     Float
  day        Int
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  pendingToId String?
  pendingTo   PendingTo? @relation(fields: [pendingToId], references: [id])
  waives     RecurringExpenseWaive[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model RecurringExpenseWaive {
  id                 String           @id @default(cuid())
  monthKey           String // e.g., "2026-03"
  recurringExpenseId String
  recurringExpense   RecurringExpense @relation(fields: [recurringExpenseId], references: [id], onDelete: Cascade)
  propertyId         String
  property           Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now())

  @@unique([monthKey, recurringExpenseId, propertyId])
}
